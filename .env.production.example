# TrendTok AI - Production Environment Variables
# Copy this file to .env.production and fill in your actual values

# ========== DATABASE ==========
# Get this from Vercel Postgres or your PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:port/dbname

# ========== DIFY CLOUD ==========
# Get API Key from https://dify.ai (Account Settings → API Keys)
VITE_DIFY_API_KEY=dify_sk_xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_DIFY_API_URL=https://api.dify.ai/v1

# ========== EXTERNAL APIs ==========
# TinyFish API key (from agent.tinyfish.ai/api-keys)
VITE_TINYFISH_API_KEY=tf_xxxxxxxxxxxxxxxxxxxxx

# Google Cloud API key (from Google Cloud Console)
# Must have Google Veo API enabled
VITE_GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key (from https://platform.openai.com/api-keys)
# Used by Dify for Claude LLM calls
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TikTok API credentials (from https://developer.tiktok.com)
VITE_TIKTOK_CLIENT_KEY=xxxxxxxxxxxxxxxxxxxx
VITE_TIKTOK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
VITE_TIKTOK_USER_TOKEN=your_user_access_token

# Instagram/Meta API (optional, for future multi-platform support)
# VITE_META_APP_ID=xxxxxxxxxxxx
# VITE_META_APP_SECRET=xxxxxxxxxxxxxxxxxxxx
# VITE_INSTAGRAM_TOKEN=your_token

# YouTube API (optional, for future multi-platform support)
# VITE_YOUTUBE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== MONITORING & TRACKING ==========
# Sentry error tracking (from https://sentry.io)
# VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Google Analytics 4 (from https://analytics.google.com)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ========== APP CONFIGURATION ==========
# Node environment
NODE_ENV=production

# App URL (for redirects, CORS, etc.)
VITE_APP_URL=https://trendtok-dashboard.vercel.app

# Dify workflow IDs (get from Dify Studio after publishing workflows)
VITE_WORKFLOW_ID_TRENDS=your_trend_discovery_workflow_id
VITE_WORKFLOW_ID_VIDEO=your_video_generation_workflow_id
VITE_WORKFLOW_ID_POST=your_tiktok_posting_workflow_id
VITE_WORKFLOW_ID_ANALYTICS=your_performance_tracking_workflow_id

# ========== FEATURE FLAGS ==========
# Enable/disable features
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_AUTOMATIONS=true

# ========== DEVELOPMENT ==========
# (Don't use in production)
# DEBUG=trendtok:*
# LOG_LEVEL=debug

